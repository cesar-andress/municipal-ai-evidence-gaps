# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.env

# Jupyter
.ipynb_checkpoints/

# Data (tracked structure only; large or sensitive files stay local)
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/*_template.csv
data/external/*
!data/external/.gitkeep

# Generated outputs
outputs/tables/*
!outputs/tables/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
outputs/reports/*
!outputs/reports/.gitkeep

# OS and editors
.DS_Store
.idea/
.vscode/
*.swp
*~

# Testing
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
